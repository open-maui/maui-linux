<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!--
    OpenMaui Linux Build Targets
    Handles MauiImage and MauiIcon items for Linux platform since we don't use the full MAUI SDK targets.
    Also manages platform folder exclusions so developers don't need boilerplate in their csproj.
  -->

  <!--
    Platform folder management: On Linux, exclude other platform folders.
    On non-Linux, exclude the Linux platform folder.
    This runs after the project file, so it adds Remove items for platform folders
    that don't apply to the current build host.
  -->
  <ItemGroup Condition="$([MSBuild]::IsOSPlatform('Linux'))">
    <Compile Remove="Platforms\Windows\**" />
    <Compile Remove="Platforms\Android\**" />
    <Compile Remove="Platforms\iOS\**" />
    <Compile Remove="Platforms\MacCatalyst\**" />
    <Compile Remove="Platforms\Tizen\**" />
    <None Remove="Platforms\Windows\**" />
    <None Remove="Platforms\Android\**" />
    <None Remove="Platforms\iOS\**" />
    <None Remove="Platforms\MacCatalyst\**" />
    <None Remove="Platforms\Tizen\**" />
    <MauiXaml Remove="Platforms\Windows\**" />
    <MauiXaml Remove="Platforms\Android\**" />
    <MauiXaml Remove="Platforms\iOS\**" />
    <MauiXaml Remove="Platforms\MacCatalyst\**" />
    <MauiXaml Remove="Platforms\Tizen\**" />
  </ItemGroup>
  <ItemGroup Condition="!$([MSBuild]::IsOSPlatform('Linux'))">
    <Compile Remove="Platforms\Linux\**" />
    <None Remove="Platforms\Linux\**" />
    <MauiXaml Remove="Platforms\Linux\**" />
  </ItemGroup>

  <!-- Copy MauiImage items to output directory after Build -->
  <Target Name="CopyMauiImagesToOutput" AfterTargets="Build" Condition="@(MauiImage) != ''">
    <Message Importance="normal" Text="OpenMaui: Copying MauiImage items to output..." />
    <Copy SourceFiles="@(MauiImage)" DestinationFolder="$(OutputPath)" SkipUnchangedFiles="true" />
  </Target>

  <!-- Copy MauiImage items to publish directory after Publish -->
  <Target Name="CopyMauiImagesToPublish" AfterTargets="Publish" Condition="@(MauiImage) != ''">
    <Message Importance="normal" Text="OpenMaui: Copying MauiImage items to publish folder..." />
    <Copy SourceFiles="@(MauiImage)" DestinationFolder="$(PublishDir)" SkipUnchangedFiles="true" />
  </Target>

  <!-- Process MauiIcon: copy foreground SVG and generate appicon.meta for runtime icon generation -->
  <Target Name="ProcessMauiIconForOutput" AfterTargets="Build" Condition="@(MauiIcon) != ''">
    <Message Importance="normal" Text="OpenMaui: Processing MauiIcon for output..." />

    <!-- Copy the foreground SVG as appicon_fg.svg -->
    <Copy SourceFiles="%(MauiIcon.ForegroundFile)"
          DestinationFiles="$(OutputPath)appicon_fg.svg"
          SkipUnchangedFiles="true"
          Condition="'%(MauiIcon.ForegroundFile)' != '' AND Exists('%(MauiIcon.ForegroundFile)')" />

    <!-- Generate appicon.meta with icon metadata -->
    <PropertyGroup>
      <_MauiIconColor Condition="'%(MauiIcon.Color)' != ''">%(MauiIcon.Color)</_MauiIconColor>
      <_MauiIconColor Condition="'%(MauiIcon.Color)' == '' AND '%(MauiIcon.BackgroundColor)' != ''">%(MauiIcon.BackgroundColor)</_MauiIconColor>
      <_MauiIconColor Condition="'$(_MauiIconColor)' == ''">Purple</_MauiIconColor>
      <_MauiIconBgColor Condition="'%(MauiIcon.BackgroundColor)' != ''">%(MauiIcon.BackgroundColor)</_MauiIconBgColor>
      <_MauiIconBgColor Condition="'$(_MauiIconBgColor)' == ''">$(_MauiIconColor)</_MauiIconBgColor>
    </PropertyGroup>

    <WriteLinesToFile
      File="$(OutputPath)appicon.meta"
      Lines="Color=$(_MauiIconBgColor);Size=256;Scale=0.65"
      Overwrite="true" />

    <Message Importance="normal" Text="OpenMaui: Generated appicon.meta (Color=$(_MauiIconBgColor))" />
  </Target>

  <!-- Process MauiIcon for Publish -->
  <Target Name="ProcessMauiIconForPublish" AfterTargets="Publish" Condition="@(MauiIcon) != ''">
    <Copy SourceFiles="%(MauiIcon.ForegroundFile)"
          DestinationFiles="$(PublishDir)appicon_fg.svg"
          SkipUnchangedFiles="true"
          Condition="'%(MauiIcon.ForegroundFile)' != '' AND Exists('%(MauiIcon.ForegroundFile)')" />

    <PropertyGroup>
      <_MauiIconColor Condition="'%(MauiIcon.Color)' != ''">%(MauiIcon.Color)</_MauiIconColor>
      <_MauiIconColor Condition="'%(MauiIcon.Color)' == '' AND '%(MauiIcon.BackgroundColor)' != ''">%(MauiIcon.BackgroundColor)</_MauiIconColor>
      <_MauiIconColor Condition="'$(_MauiIconColor)' == ''">Purple</_MauiIconColor>
      <_MauiIconBgColor Condition="'%(MauiIcon.BackgroundColor)' != ''">%(MauiIcon.BackgroundColor)</_MauiIconBgColor>
      <_MauiIconBgColor Condition="'$(_MauiIconBgColor)' == ''">$(_MauiIconColor)</_MauiIconBgColor>
    </PropertyGroup>

    <WriteLinesToFile
      File="$(PublishDir)appicon.meta"
      Lines="Color=$(_MauiIconBgColor);Size=256;Scale=0.65"
      Overwrite="true" />
  </Target>

</Project>
